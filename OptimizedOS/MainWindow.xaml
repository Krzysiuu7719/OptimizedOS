<Window x:Class="OptimizedOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptimizedOS.ViewModels"
        xmlns:conv="clr-namespace:OptimizedOS.Converters"
        Title="OptimizedOS"
        Width="500" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBgBrush}"
        FontFamily="Segoe UI"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>
    </Window.Resources>

    <Border Background="{StaticResource WindowBgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="OptimizedOS"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnMinimize"
                            Content="&#xE949;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource TitleBarButton}"
                            Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnClose"
                            Content="&#xE106;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource TitleBarButton}"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="40,20,40,36">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Centered Header + Button -->
                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,24">

                    <!-- Logo Icon -->
                    <TextBlock Text="&#xE777;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="48"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="OptimizedOS"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Windows Optimization Tool"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,3"/>

                    <TextBlock Text="{Binding ManifestVersion}"
                               FontSize="11"
                               Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18"
                               Visibility="{Binding IsVersionVisible, Converter={StaticResource BoolVis}}"/>

                    <Button Style="{StaticResource StartButtonStyle}"
                            Content="START"
                            Command="{Binding StartCommand}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsFinished, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"/>

                    <Button Style="{StaticResource RestartButtonStyle}"
                            Content="RESTART PC"
                            Command="{Binding RestartCommand}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsFinished, Converter={StaticResource BoolVis}}"/>
                </StackPanel>

                <!-- Log Panel -->
                <Border Grid.Row="1"
                        Background="{StaticResource PanelBgBrush}"
                        CornerRadius="8"
                        Padding="0"
                        Margin="0,0,0,16"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="LOG"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="14,10,14,6"/>

                        <ScrollViewer Grid.Row="1"
                                      x:Name="LogScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding LogLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}"
                                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Padding="14,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="1"
                                   Text="Press START to begin"
                                   FontSize="13"
                                   Foreground="{StaticResource TextDimBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding LogLines.Count, Converter={StaticResource ZeroToVisibility}}"/>
                    </Grid>
                </Border>

                <!-- Progress Bar -->
                <ProgressBar Grid.Row="2"
                             Value="{Binding Progress}"
                             Maximum="100"
                             Margin="0,0,0,12"/>

                <!-- Status -->
                <TextBlock Grid.Row="3"
                           Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>

                <!-- Author Credit -->
                <TextBlock Grid.Row="3"
                           Text="by krzysi_x"
                           FontSize="9"
                           Foreground="{StaticResource TextDimBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,-20"/>
            </Grid>
        </Grid>
    </Border>
</Window>
